# Staff Portal environment variables
# Copy to .env.local and fill in actual values — never commit .env.local

# Azure Entra ID (MSAL)
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/

# API Gateway base URL
VITE_API_BASE_URL=https://api.dev.crmplatform.example.com

# App Insights (optional in dev)
VITE_APP_INSIGHTS_CONNECTION_STRING=
